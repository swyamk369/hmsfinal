# ─────────────────────────────────────────────────────────────
# Production env for infra/docker-compose.prod.yml.
# Copy to infra/.env.production and fill in. NEVER commit the filled file.
# ─────────────────────────────────────────────────────────────

# Postgres (self-hosted service in the compose; omit if using managed Postgres).
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE-ME-strong-owner-password
POSTGRES_DB=hms

# Connection strings.
#  - DATABASE_URL: the OWNER role (migrations, RLS apply, seed, platform/auth client).
#  - APP_DATABASE_URL: a NON-owner role (hms_app) so FORCE RLS isolates tenants.
# Use the service name `postgres` as host inside the compose network.
DATABASE_URL=postgresql://postgres:CHANGE-ME-strong-owner-password@postgres:5432/hms?schema=public
APP_DATABASE_URL=postgresql://hms_app:CHANGE-ME-strong-app-password@postgres:5432/hms?schema=public

# API.
API_PORT=4000
# Comma-separated production web origin(s). MUST NOT be localhost.
CORS_ORIGIN=https://app.your-hospital-domain.com
THROTTLE_LIMIT=300
THROTTLE_TTL_MS=60000

# Firebase Admin service account JSON — absolute path on the HOST, mounted
# read-only into the api container. Generate in Firebase console.
FIREBASE_SERVICE_ACCOUNT_FILE=/opt/hms/secrets/firebase-service-account.json

# Google AI key for the in-app HMS Assistant chatbot.
GOOGLE_GENERATIVE_AI_API_KEY=CHANGE-ME-google-ai-api-key

# Web.
WEB_PORT=4001

# NOTE: NEXT_PUBLIC_* (API URL + Firebase web config) are baked into the web
# image at BUILD time via --build-arg, not here. See apps/web/Dockerfile.
