# ─────────────────────────────────────────────────────────────
# HMS SaaS — environment template. Copy to .env and fill in.
# ─────────────────────────────────────────────────────────────

# ── Database (two roles for RLS) ──────────────────────────────
# Owner connection: bypasses RLS. Used by Prisma migrations, seed,
# and the platform/auth cross-tenant client.
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/hms?schema=public"

# App connection: a NON-owner role so Postgres FORCE RLS isolates
# every tenant query. Created by `pnpm db:rls` (see packages/db/sql/rls.sql).
APP_DATABASE_URL="postgresql://hms_app:app_pw@localhost:5433/hms?schema=public"

# ── API ───────────────────────────────────────────────────────
API_PORT=4000
NODE_ENV=development
# Comma-separated allow-list of web origins. In production this MUST be set and
# MUST NOT contain localhost (the API refuses to boot otherwise).
CORS_ORIGIN=http://localhost:4001

# ── Rate limiting (Phase 16) — production defaults are safe ────
# Global per-IP limit; auth-sensitive routes add stricter @Throttle overrides.
# Do NOT raise this for production; the E2E suite uses a high override on the
# dev process only. >10000 is rejected by env validation in production.
THROTTLE_LIMIT=300
THROTTLE_TTL_MS=60000

# ── Firebase Admin (REQUIRED — auth is Firebase-only) ─────────
# Either set FIREBASE_* below, OR point GOOGLE_APPLICATION_CREDENTIALS at a
# service-account JSON file (preferred in container deploys via a mounted secret).
# Firebase console → Project settings → Service accounts → Generate new private key.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Paste the private key on one line with literal \n for newlines.
FIREBASE_PRIVATE_KEY=
# GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/firebase-service-account.json

# ── AI assistant ──────────────────────────────────────────────
# Required for the in-app HMS Assistant chatbot.
GOOGLE_GENERATIVE_AI_API_KEY=

# ── Super Admin bootstrap (used once by bootstrap:superadmin) ──
SUPERADMIN_EMAIL=
SUPERADMIN_PASSWORD=
SUPERADMIN_NAME=Platform Super Admin

# ── Web (Next.js) ─────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
# Firebase web SDK config (Project settings → General → Your apps → Web).
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ── Optional: notification providers (Phase 15) ───────────────
# If unset, external delivery is recorded as SKIPPED (in-app always works).
# NOTIFICATION_EMAIL_PROVIDER=
# NOTIFICATION_EMAIL_API_KEY=
# NOTIFICATION_SMS_PROVIDER=
# NOTIFICATION_SMS_API_KEY=
# NOTIFICATION_WHATSAPP_PROVIDER=
# NOTIFICATION_WHATSAPP_API_KEY=

# ── Optional: error tracking / monitoring ─────────────────────
# Wire to your provider (e.g. Sentry). Unset = disabled.
# SENTRY_DSN=
# LOG_LEVEL=info
